generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
  MODERATOR
}

enum List {
  WATCHING
  PLANNED
  COMPLETED
  ABANDONED
  FAVORITE
}

enum AnimeStatus {
  ONGOING
  COMPLETED
  ANNOUNCEMENT
}

enum AnimeType {
  TVSERIES
  MOVIE
  SHORTFILM
  SPECIAL
  OVA
  ONA
  CLIP
}

model User {
  id                     String        @id @default(cuid(2))
  name                   String        @default("guest")
  email                  String        @unique
  role                   Role          @default(USER)
  emailVerified          Boolean       @default(false)
  isReceiveNotifications Boolean       @default(false)
  image                  String?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
  sessions               Session[]
  accounts               Account[]
  comments               Comment[]
  ratings                AnimeRating[]
  lists                  UserList[]
  likes                  CommentLike[]

  @@map("user")
}

model UserList {
  id        String   @id @default(cuid(2))
  userId    String   @map("user_id")
  animeId   String   @map("anime_id")
  list      List
  addedAt   DateTime @default(now()) @map("added_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  anime Anime @relation(fields: [animeId], references: [id], onDelete: Cascade)

  @@unique([animeId, userId])
  @@map("lists")
}

model CommentLike {
  id        String  @id @default(cuid(2))
  commentId String  @map("comment_id")
  userId    String  @map("user_id")
  isLiked   Boolean @map("is_liked")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@map("comment_likes")
}

model Comment {
  id        String        @id @default(cuid(2))
  text      String        @db.Text
  userId    String        @map("user_id")
  episodeId String        @map("episode_id")
  likes     CommentLike[]
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  episode AnimeEpisode @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([episodeId])
  @@index([userId])
  @@map("comments")
}

model Session {
  id        String   @id @default(cuid(2))
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @default(cuid(2))
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String    @id @default(cuid(2))
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verification")
}

model Anime {
  id               String         @id @default(cuid(2))
  slug             String         @unique
  title            String
  image            String?
  originalTitle    String?        @map("original_title")
  description      String         @db.Text
  ageLimit         Int            @map("age_limit")
  genres           AnimeGenre[]
  releaseYear      Int            @map("release_year")
  episodesReleased Int            @map("episodes_released")
  episodesCount    Int            @map("episodes_count")
  episodesLength   Int            @map("episodes_length")
  type             AnimeType      @default(TVSERIES)
  status           AnimeStatus    @default(ANNOUNCEMENT)
  views            Int            @default(0)
  episodes         AnimeEpisode[]
  ratings          AnimeRating[]
  list             UserList[]

  @@index([title])
  @@index([releaseYear])
  @@index([ageLimit])
  @@index([status])
  @@index([type])
  @@map("anime")
}

model AnimeRating {
  id        String   @id @default(cuid(2))
  animeId   String   @map("anime_id")
  userId    String   @map("user_id")
  rating    Float    @default(0.0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  anime     Anime    @relation(fields: [animeId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([animeId, userId])
  @@index([animeId])
  @@index([userId])
  @@map("anime_ratings")
}

model AnimeEpisode {
  id            String    @id @default(cuid(2))
  url           String    @unique
  episodeNumber Int       @map("episode_number")
  views         Int       @default(0)
  animeId       String    @map("anime_id")
  comments      Comment[]

  anime Anime @relation(fields: [animeId], references: [id], onDelete: Cascade)

  @@unique([animeId, episodeNumber])
  @@map("anime_episodes")
}

model AnimeGenre {
  id    Int     @id @default(autoincrement())
  name  String  @unique
  anime Anime[]

  @@map("anime_genres")
}
