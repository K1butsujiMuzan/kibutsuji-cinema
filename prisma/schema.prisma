generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
  MODERATOR
}

model User {
  id                     String    @id @default(cuid(2))
  name                   String    @default("guest")
  email                  String    @unique
  role                   Role      @default(USER)
  emailVerified          Boolean   @default(false)
  isReceiveNotifications Boolean   @default(false)
  image                  String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  sessions               Session[]
  accounts               Account[]

  @@map("user")
}

model Session {
  id        String   @id @default(cuid(2))
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @default(cuid(2))
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String    @id @default(cuid(2))
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verification")
}

model Anime {
  id            String  @id @default(cuid(2))
  title         String
  originalTitle String? @map("original_title")
  ageLimit      Int     @map("age_limit")
  tags          Tag[]
  typeId        Int     @map("type_id")
  releaseYearId Int     @map("release_year_id")

  type        AnimeType   @relation(fields: [typeId], references: [id])
  releaseYear ReleaseYear @relation(fields: [releaseYearId], references: [id])

  @@index([releaseYearId])
  @@index([typeId])
  @@map("animes")
}

model ReleaseYear {
  id     Int     @id @default(autoincrement())
  year   Int     @unique
  animes Anime[]

  @@map("release_years")
}

model AnimeType {
  id     Int     @id @default(autoincrement())
  name   String  @unique
  animes Anime[]

  @@map("anime_types")
}

model Tag {
  id    Int     @id @default(autoincrement())
  name  String  @unique
  anime Anime[]

  @@map("tags")
}
