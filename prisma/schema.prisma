generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
  MODERATOR
}

enum List {
  WATCHING
  PLANNED
  COMPLETED
  ABANDONED
  FAVORITE
}

enum AnimeStatus {
  ONGOING
  COMPLETED
  ANNOUNCEMENT
}

enum AnimeType {
  TVSERIES
  MOVIE
  SHORTFILM
  SPECIAL
  OVA
  ONA
  CLIP
}

enum AgeLimit {
  AGE_6
  AGE_12
  AGE_16
  AGE_18
}

enum LikeValue {
  LIKE
  DISLIKE
}

enum SubscriptionType {
  FAN
  MEGAFAN
}

enum AnimeAccessType {
  FREE
  PAID
}

model User {
  id                     String  @id @default(cuid())
  name                   String
  email                  String  @unique
  role                   Role    @default(USER)
  emailVerified          Boolean @default(false)
  isReceiveNotifications Boolean @default(false)
  image                  String?

  sessions     Session[]
  accounts     Account[]
  comments     Comment[]
  ratings      AnimeRating[]
  lists        UserList[]
  likes        CommentLike[]
  subscription Subscription?
  transactions Transaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user")
}

model UserList {
  id   String @id @default(cuid())
  list List

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  animeId String @map("anime_id")
  anime   Anime  @relation(fields: [animeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([animeId, userId])
  @@map("lists")
}

model CommentLike {
  id    String    @id @default(cuid())
  value LikeValue

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  commentId String  @map("comment_id")
  comment   Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([commentId, userId])
  @@map("comment_likes")
}

model Comment {
  id   String @id @default(cuid())
  text String @db.Text

  episodeId String       @map("episode_id")
  episode   AnimeEpisode @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  userId        String @map("user_id")
  user          User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  commentRating Int    @default(0) @map("comment_rating")

  likes CommentLike[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([episodeId])
  @@index([userId])
  @@map("comments")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime

  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt

  @@map("verification")
}

model Anime {
  id               String          @id @default(cuid())
  slug             String          @unique
  title            String
  image            String?
  backgroundImage  String?         @map("background_image")
  originalTitle    String?         @map("original_title")
  description      String?         @db.Text
  ageLimit         AgeLimit        @map("age_limit")
  releaseDate      DateTime        @map("release_date")
  rating           Float           @default(0)
  episodesCount    Int             @map("episodes_count")
  episodesReleased Int             @default(0) @map("episodes_released")
  episodesLength   Int             @map("episodes_length")
  type             AnimeType       @default(TVSERIES)
  status           AnimeStatus     @default(ANNOUNCEMENT)
  views            Int             @default(0)
  access           AnimeAccessType @default(FREE)

  genres   AnimeGenre[]
  episodes AnimeEpisode[]
  ratings  AnimeRating[]
  list     UserList[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([title])
  @@index([releaseDate])
  @@index([ageLimit])
  @@index([status])
  @@index([type])
  @@map("anime")
}

model AnimeRating {
  id     String @id @default(cuid())
  rating Float  @default(0.0)

  animeId String @map("anime_id")
  anime   Anime  @relation(fields: [animeId], references: [id], onDelete: Cascade)

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([animeId, userId])
  @@index([animeId])
  @@index([userId])
  @@map("anime_ratings")
}

model AnimeEpisode {
  id            String @id @default(cuid())
  episodeNumber Int    @default(1) @map("episode_number")
  title         String
  views         Int    @default(0)

  animeId String @map("anime_id")
  anime   Anime  @relation(fields: [animeId], references: [id], onDelete: Cascade)

  comments Comment[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([animeId, episodeNumber])
  @@index([title])
  @@map("anime_episodes")
}

model AnimeGenre {
  id   String @id @default(cuid())
  name String @unique

  anime Anime[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("anime_genres")
}

model Subscription {
  id      String           @id @default(cuid())
  type    SubscriptionType
  endDate DateTime         @map("end_date")

  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([endDate])
  @@index([userId])
  @@map("subscriptions")
}

model Transaction {
  id           String           @id @default(cuid())
  sum          Float
  subscription SubscriptionType

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("transactions")
}
