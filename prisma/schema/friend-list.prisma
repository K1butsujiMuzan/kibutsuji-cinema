model FriendList {
  id     String           @id @default(cuid())
  status FriendListStatus @default(PENDING)

  userFromId String @map("user_from_id")
  userFrom   User   @relation(name: "sentRequests", fields: [userFromId], references: [id], onDelete: Cascade)

  userToId String @map("user_to_id")
  userTo   User   @relation(name: "receivedRequests", fields: [userToId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userFromId, userToId])
  @@map("friend_lists")
}
